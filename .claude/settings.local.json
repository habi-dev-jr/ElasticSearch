      "Bash(curl -s -k -u admin:admin -X POST https://localhost:9200/nrt_demo/_search -H 'Content-Type: application/json' -d '{\"query\":{\"match_all\":{}}}')",
      "Bash(curl -s -k -u admin:admin https://localhost:9200/nrt_demo/_doc/1)"
