      "Bash(curl -s -k -u admin:admin \"https://localhost:9200/products/_search?pretty&size=20&_source=name\")",
      "Bash(python3 -c \"import sys,json; d=json.load\\(sys.stdin\\); print\\('total:', d['hits']['total']['value']\\); [print\\(' ', h['_id'], '->', h['_source']['name']\\) for h in sorted\\(d['hits']['hits'], key=lambda x:int\\(x['_id']\\)\\)]\")",
